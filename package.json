{
  "name": "multi-ai-sdk",
  "version": "2.0.2",
  "description": "Universal multi-provider AI SDK. Single lightweight API for 18 providers (Groq, OpenAI, Gemini, Claude, Mistral, DeepSeek, etc). Features: auto-fallback, JSON repair, context window guards, and embeddable chat widget.",
  "keywords": [
    "ai-sdk",
    "groq",
    "openai",
    "gemini",
    "claude",
    "anthropic",
    "mistral",
    "deepseek",
    "cohere",
    "ollama",
    "qwen",
    "grok",
    "nvidia-nim",
    "together-ai",
    "perplexity",
    "llm",
    "ai-assistant",
    "chat-widget",
    "streaming-llm",
    "token-budget",
    "ai-client",
    "zero-dependency",
    "typescript"
  ],
  "author": {
    "name": "adarshchaudhary",
    "url": "https://github.com/codewithAdarsh1"
  },
  "license": "MIT",
  "homepage": "https://github.com/codewithAdarsh1/simple-groq#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codewithAdarsh1/simple-groq.git"
  },
  "bugs": {
    "url": "https://github.com/codewithAdarsh1/simple-groq/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"No tests yet\" && exit 0",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
