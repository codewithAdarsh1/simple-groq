{
  "name": "multi-ai-sdk",
  "version": "2.0.3",
  "description": "Universal AI SDK — one API for OpenAI, Anthropic Claude, Google Gemini, Groq, Mistral, DeepSeek, Grok, Ollama & 10 more. Zero dependencies, pure fetch. Auto-fallback, streaming, JSON repair, embeddable chat widget. Works in Node.js, Bun, Deno, Cloudflare Workers.",
  "keywords": [
    "ai",
    "ai-sdk",
    "llm",
    "openai",
    "anthropic",
    "claude",
    "groq",
    "gemini",
    "google-ai",
    "mistral",
    "deepseek",
    "ollama",
    "local-llm",
    "grok",
    "xai",
    "cohere",
    "perplexity",
    "together-ai",
    "nvidia-nim",
    "fireworks",
    "cerebras",
    "moonshot",
    "qwen",
    "multi-provider",
    "ai-wrapper",
    "llm-client",
    "chat-completion",
    "streaming",
    "streaming-llm",
    "ai-chat",
    "chatbot",
    "chat-widget",
    "embed-chat",
    "json-repair",
    "structured-output",
    "token-budget",
    "fallback",
    "rate-limit",
    "zero-dependency",
    "typescript",
    "isomorphic",
    "edge-runtime",
    "cloudflare-workers",
    "bun",
    "deno",
    "node"
  ],
  "author": {
    "name": "adarshchaudhary",
    "url": "https://github.com/codewithAdarsh1"
  },
  "license": "MIT",
  "homepage": "https://github.com/codewithAdarsh1/multi-ai-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codewithAdarsh1/multi-ai-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/codewithAdarsh1/multi-ai-sdk/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
