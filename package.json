{
  "name": "groq-client",
  "version": "1.0.4",
  "description": "A lightweight, zero-config Groq API wrapper for Node.js/TypeScript with streaming, chat history, and built-in model constants.",
  "keywords": [
    "groq",
    "llm",
    "ai",
    "llama",
    "mixtral",
    "gemma",
    "typescript",
    "streaming",
    "chat",
    "openai-compatible"
  ],
  "author": {
    "name": "adarshchaudhary",
    "url": "https://github.com/codewithAdarsh1"
  },
  "license": "MIT",
  "homepage": "https://github.com/codewithAdarsh1/groq-client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codewithAdarsh1/groq-client.git"
  },
  "bugs": {
    "url": "https://github.com/codewithAdarsh1/groq-client/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"No tests yet\" && exit 0",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
